QDialog {
    background-color: #2D2D2D;
    border-radius: 10px;
    padding: 10px;
}
QLabel {
    font-family: 'Arial';
    font-size: 12pt;
    color: white;
}
QLabel#title_label {
    font-size: 14pt;
    font-weight: bold;
    color: #0076D1;
}
QPushButton {
    font-family: 'Arial';
    font-size: 12pt;
    background-color: #0076D1;
    color: white;
    padding: 10px;
    border: none;
    border-radius: 10px;
    width: 100%;
}
QPushButton:hover {
    background-color: #005BB5;
}
