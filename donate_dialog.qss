QDialog {
    background-color: #2D2D2D;
    border-radius: 10px;
}
QLabel {
    font-family: 'Arial';
    font-size: 12pt;
    color: white;
}
QLabel#title_label {
    font-size: 16pt;
    font-weight: bold;
    color: #0076D1;
}
QPushButton {
    font-family: 'Arial';
    font-size: 12pt;
    background-color: white;
    color: #000000;
    border-radius: 5px;
}
